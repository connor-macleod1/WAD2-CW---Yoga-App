{{> head}}
{{> header}}

<div class="wrap">
  <article>
    <h1>{{course.title}}</h1>
    <p class="muted">
      Level: {{course.level}} • Type: {{course.type}} 
      {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
    </p>
    <p>{{course.description}}</p>
    <p class="muted">Dates: {{course.startDate}} – {{course.endDate}}</p>

    {{#user}}
    <section>
      <h2>Enrol in course</h2>
      <form action="/courses/{{course.id}}/book" method="post">
        <button class="btn primary" type="submit">Enrol in course</button>
      </form>
    </section>
    {{/user}}

    {{^user}}
    <p class="muted">
      <a href="/login">Sign in</a> to book this course.
    </p>
    {{/user}}

    <section>
      <h2>Sessions</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Start</th>
            <th>End</th>
            <th>Duration</th>
            <th>Location</th>
            <th>Price</th>
            <th>Capacity</th>
            <th>Remaining</th>
            <th></th>
          </tr>
        </thead>
          <tbody>
            {{#sessions}}
            <tr>
              <td><a href="/sessions/{{id}}">{{start}}</a></td>
              <td>{{end}}</td>
              <td>{{duration}}</td>
              <td>{{location}}</td>
              <td>£{{price}}</td>
              <td>{{capacity}}</td>
              <td>{{remaining}}</td>
              <td>
                {{#../course.allowDropIn}}
                  {{#../user}}
                  <form method="post" action="/sessions/{{id}}/book">
                    <button class="btn" type="submit">Book session</button>
                  </form>
                  {{/../user}}
                  {{^../user}}
                  <a href="/login" class="btn">Sign in to book</a>
                  {{/../user}}
                {{/../course.allowDropIn}}
                {{^../course.allowDropIn}}
                <span class="muted">Drop-ins disabled</span>
                {{/../course.allowDropIn}}
              </td>
            </tr>
            {{/sessions}}
          </tbody>
      </table>
    </section>
  </article>
</div>

{{> footer}}