{{> head}}
{{> header}}

<div class="wrap">
  <h1>{{ title }}</h1>

  {{#errors}}
  <div class="alert error" role="alert">
    <p>{{message}}</p>
  </div>
  {{/errors}}

  <form method="post" action="/login">
    <div class="field">
      <label for="email">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="Enter your email"
        required
      />
    </div>

    <div class="field">
      <label for="password">Password</label>
      <input
        type="password"
        id="password"
        name="password"
        placeholder="Enter your password"
        required
      />
    </div>

    <div class="actions">
      <button type="submit" class="btn primary">Sign In</button>
      <a href="/register" class="btn">No account? Register</a>
    </div>
  </form>
</div>

{{> footer}}