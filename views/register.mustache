{{> head}}
{{> header}}

<div class="wrap">
  <h1>{{ title }}</h1>

  {{#errors}}
  <div class="alert error" role="alert">
    <p>{{message}}</p>
  </div>
  {{/errors}}

  <form method="post" action="/register">
    <div class="field">
      <label for="name">Full Name</label>
      <input
        type="text"
        class="form-control"
        id="name"
        name="name"
        placeholder="Enter your full name"
        required
      />
    </div>

    <div class="field">
      <label for="email">Email</label>
      <input
        type="email"
        class="form-control"
        id="email"
        name="email"
        placeholder="Enter your email"
        required
      />
    </div>
    <div class="field">
      <label for="role">Role</label>
      <input
        type="text"
        class="form-control"
        id="role"
        name="role"
        placeholder="Enter your role"
        required
      />
    </div>
    <div class="field">
      <label for="password">Password (8 characters minimum)</label>
      <input
        type="password"
        class="form-control"
        id="password"
        name="password"
        placeholder="Enter password"
        minlength="8"
        required
      />
    </div>

    <div class="actions">
      <button type="submit" class="btn primary">Register</button>
      <a href="/login" class="btn">Already have an account? Sign in</a>
    </div>
  </form>
</div>

{{> footer}}