{{> head}}
{{> header}}

<div class="wrap">
  <h1>{{ title }}</h1>

  {{#errors}}
  <div class="alert error" role="alert">
    <p>{{message}}</p>
  </div>
  {{/errors}}

  <form method="post" action="{{action}}">
    <div class="field">
      <label for="startDateTime">Start Date and Time</label>
      <input
        type="datetime-local"
        id="startDateTime"
        name="startDateTime"
        value="{{session.startDateTime}}"
        required
      />
    </div>

    <div class="field">
      <label for="endDateTime">End Date and Time</label>
      <input
        type="datetime-local"
        id="endDateTime"
        name="endDateTime"
        value="{{session.endDateTime}}"
        required
      />
    </div>

    <div class="field">
      <label for="capacity">Capacity</label>
      <input
        type="number"
        id="capacity"
        name="capacity"
        value="{{session.capacity}}"
        min="1"
        placeholder="Enter maximum capacity"
        required
      />
    </div>
     <div class="field">
      <label for="location">Location</label>
      <input
        type="text"
        id="location"
        name="location"
        value="{{session.location}}"
        placeholder="Enter session location"
        required
      />
    </div>

    <div class="field">
      <label for="price">Price (£)</label>
      <input
        type="number"
        id="price"
        name="price"
        value="{{session.price}}"
        min="0"
        step="0.01"
        placeholder="Enter session price"
        required
      />
    </div>

    <div class="actions">
      <button type="submit" class="btn primary">Save Session</button>
      <a href="/organiser" class="btn">Cancel</a>
    </div>
  </form>
</div>

{{> footer}}