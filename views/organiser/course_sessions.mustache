{{> head}}
{{> header}}

<div class="wrap">
  <h1>{{title}}</h1>

  <a href="/organiser" class="btn">← Back to Dashboard</a>

  <div style="display:flex; justify-content:space-between; align-items:center; margin-top:20px;">
    <h2>Sessions</h2>
    <a href="/organiser/courses/{{course._id}}/sessions/new" class="btn primary">
      Add Session
    </a>
  </div>

  {{#hasSessions}}
  <table class="table">
    <thead>
      <tr>
        <th>Start</th>
        <th>End</th>
        <th>Duration</th>      
        <th>Location</th>
        <th>Price</th>
        <th>Capacity</th>
        <th>Booked</th>
        <th>Remaining</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      {{#sessions}}
      <tr>
        <td>{{start}}</td>
        <td>{{end}}</td>
        <td>{{duration}}</td>
        <td>{{location}}</td>
        <td>£{{price}}</td>
        <td>{{capacity}}</td>
        <td>{{booked}}</td>
        <td>{{remaining}}</td>
        <td>
          <a href="/organiser/sessions/{{id}}/edit" class="btn">Edit</a>
          <a href="/organiser/sessions/{{id}}/participants" class="btn">Class List</a>
          <form method="post" action="/organiser/sessions/{{id}}/delete" style="display:inline;">
            <button class="btn" type="submit">Delete</button>
          </form>
        </td>
      </tr>
      {{/sessions}}
    </tbody>
  </table>
  {{/hasSessions}}

  {{^hasSessions}}
  <p class="muted">No sessions for this course yet.</p>
  {{/hasSessions}}

</div>

{{> footer}}