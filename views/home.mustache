{{> head}}
{{> header}}

<div class="wrap">
  <h1>Upcoming Courses</h1>

   <div class="text-end" style="margin-bottom: 1em">
      {{^user}}
      <a id="login" href="/register" class="btn btn-primary"> Register </a>
      <a id="login" href="/login" class="btn btn-primary"> Sign in </a>
      {{/user}}
      {{#user}}
      <a id="logout" href="/logout" class="btn btn-primary"> Sign out </a>
      {{/user}}
    </div>


  <div class="cards">
    {{#courses}}
    <article class="card">
      <h2><a href="/courses/{{id}}">{{title}}</a></h2>
      <p class="muted">
        Level: {{level}} • Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}
      </p>
      <p>{{description}}</p>
      <p class="muted">Dates: {{startDate}} - {{endDate}}</p>
      <p class="muted">Next session: {{nextSession}} • Sessions: {{sessionsCount}}</p>
      <p><a href="/courses/{{id}}" class="btn">View &amp; Book</a></p>
    </article>
    {{/courses}}

    {{^courses}}
    <p>No courses available yet.</p>
    {{/courses}}
  </div>
</div>

{{> footer}}